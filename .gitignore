# Distribution and Release
dist/
release/

*

# Allow directories (required for recursive matching)
!*/

# Root-level essentials
!.gitignore
!GEMINI.md
!README.md
!CHANGELOG.md
!LICENSE.md
!gemini-extension.json
!update_repos.py
!release.py
!package.py
!package.json
!package-lock.json
!.github/**

# Extension components
!skills/**
!agents/**
!policies/**
!hooks/**
!commands/**
!.agents/**
!references/**
!wiki/**

# Exclude bulky repository clones (keep only the manifest/script)
references/repositories/*/

# Global exclusions for sensitive or transient data
**/.git/**
**/node_modules/**
**/dist/**
**/build/**
**/*.log
**/.env
**/.DS_Store
**/*.bak
**/*.tmp
